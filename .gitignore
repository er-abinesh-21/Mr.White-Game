/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
pnpm-debug.log*
*.log

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# capacitor & android
/android/.gradle/
/android/.idea/
/android/.cxx/
/android/.externalNativeBuild/
/android/build/
/android/app/build/
/android/local.properties
/android/captures/
/android/app/src/main/assets/public/
*.apk
*.aab
*.keystore

# Android Studio
*.iml
.idea/

# local editor settings
.vscode/
!.vscode/extensions.json
!.vscode/settings.json

# partykit
.partykit/

